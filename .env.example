ANTHROPIC_API_KEY=sk-ant-...
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=choose-your-own-verification-string
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_NOTIFY_TO=+33600000000
# Optionnel : nom d'un template WhatsApp approuve par Meta, avec une seule
# variable texte dans le corps. Si defini, les notifications proactives
# utilisent ce template au lieu du texte libre (necessaire au-dela de la
# fenetre de 24h suivant le dernier message recu du destinataire).
WHATSAPP_NOTIFY_TEMPLATE=
WHATSAPP_NOTIFY_TEMPLATE_LANG=fr
