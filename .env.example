ANTHROPIC_API_KEY=sk-ant-...
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=choose-your-own-verification-string
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_NOTIFY_TO=+33600000000
# Optionnel : nom d'un template WhatsApp approuve par Meta, avec une seule
# variable texte dans le corps. Si defini, les notifications proactives
# utilisent ce template au lieu du texte libre (necessaire au-dela de la
# fenetre de 24h suivant le dernier message recu du destinataire).
WHATSAPP_NOTIFY_TEMPLATE=
WHATSAPP_NOTIFY_TEMPLATE_LANG=fr

# Compte email pour le module email : utiliser un mot de passe
# d'application (Gmail/Outlook...), jamais le mot de passe principal du
# compte. Activer IMAP dans les parametres du fournisseur.
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_MAILBOX=INBOX

# Recherche web en temps reel (module recherche), via l'API Perplexity
# (perplexity.ai/settings/api).
PERPLEXITY_API_KEY=pplx-...

# Connexion reelle a Google Calendar (agenda-check). Voir README, section
# Agenda, pour la procedure complete (Google Cloud Console + autorisation
# via scripts/google_oauth_setup.py). GOOGLE_REFRESH_TOKEN est produit par
# ce script, jamais a saisir a la main.
#
# Piege frequent : GOOGLE_CLIENT_ID et GOOGLE_CLIENT_SECRET viennent d'un
# "ID client OAuth" (type Application de bureau), PAS d'un "Compte de
# service" - ce sont deux types d'identifiants differents dans Google
# Cloud Console et il n'y a pas de "Client secret" sur un compte de
# service. Le Client ID finit par .apps.googleusercontent.com, le Client
# secret commence par GOCSPX- ; `python app.py doctor` verifie ce format.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
